{
  "name": "fluent",
  "description": "Language-learning platform with audio lessons, moderated comments, and admin content management. Built with Next.js, Supabase, and Drizzle ORM.",
  "author": "Fred Jones",
  "repository": {
    "type": "git",
    "url": "https://github.com/y4qq/fluent-fast-2.git"
  },
  "keywords": [
    "nextjs",
    "supabase",
    "drizzle",
    "typescript",
    "language-learning",
    "tailwind",
    "shadcn"
  ],
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "next dev --port 3100",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/prepare-test-env.mjs && node --import tsx --test tests/**/*.test.ts",
    "postinstall": "node -e \"require('fs').cpSync('node_modules/react-flagpack-react-19/dist/flags','public/flags',{recursive:true})\"",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "supabase migration up",
    "db:push": "supabase db push",
    "db:studio": "drizzle-kit studio",
    "db:diff": "supabase db diff --linked"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@radix-ui/react-checkbox": "^1.3.1",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-slot": "^1.2.2",
    "@sentry/nextjs": "^10",
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "flagpack-core": "^2.1.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.8.0",
    "next": "latest",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-flagpack-react-19": "^2.0.6",
    "react-resizable-panels": "^4.10.0",
    "shadcn": "^4.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.3.1",
    "postcss": "^8",
    "tailwindcss": "^4.2.3",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
